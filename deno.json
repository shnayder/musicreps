{
  "compilerOptions": {
    "lib": ["deno.window", "dom", "dom.iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "nodeModulesDir": "auto",
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": [
        "no-window",
        "no-explicit-any",
        "no-node-globals",
        "no-process-global"
      ]
    },
    "exclude": [
      "docs/",
      "node_modules/",
      "scripts/",
      "tests/",
      "guides/design/components-preview.html",
      "guides/design/screenshot-review.html",
      "plans/generated/",
      "android/",
      "ios/"
    ]
  },
  "fmt": {
    "singleQuote": true,
    "exclude": [
      "docs/",
      "node_modules/",
      "guides/",
      "plans/",
      "backlogs/",
      "static/",
      "android/",
      "ios/"
    ]
  },
  "tasks": {
    "build": "deno run --allow-read --allow-write --allow-run --allow-env=BUILD_NUMBER,APP_CONTACT_EMAIL,APP_SUPPORT_URL,APP_TERMS_URL,APP_PRIVACY_URL main.ts --build",
    "dev": "deno run --watch --allow-net --allow-read --allow-run --allow-env=BUILD_NUMBER,APP_CONTACT_EMAIL,APP_SUPPORT_URL,APP_TERMS_URL,APP_PRIVACY_URL main.ts",
    "test": "deno test --no-check --allow-read --allow-run=deno --ignore=tests/e2e",
    "lint": "deno lint",
    "lint:functions": "deno run -A scripts/lint-function-length.ts",
    "lint:labels": "deno run --allow-read scripts/lint-untranslated-labels.ts",
    "fmt": "deno fmt --check",
    "fmt:fix": "deno fmt",
    "check": "deno check src/**/*.ts $(find src -name '*.tsx' 2>/dev/null)",
    "ok": "deno lint && deno task lint:functions && deno task lint:labels && deno fmt --check && deno check src/**/*.ts $(find src -name '*.tsx' 2>/dev/null) && deno test --no-check --allow-read --allow-run=deno --ignore=tests/e2e && deno run --allow-read --allow-write --allow-run --allow-env=BUILD_NUMBER,APP_CONTACT_EMAIL,APP_SUPPORT_URL,APP_TERMS_URL,APP_PRIVACY_URL main.ts --build",
    "prepush": "deno task ok && deno task e2e",
    "screenshots": "npx tsx scripts/take-screenshots.ts",
    "screenshots:baseline": "npx tsx scripts/take-screenshots.ts --dir screenshots/baseline",
    "screenshots:review": "npx tsx scripts/build-screenshot-review.ts",
    "iterate": "npx tsx scripts/ui-iterate.ts",
    "screenshots:components": "npx tsx scripts/take-screenshots.ts --only comp/",
    "diagnostic": "npx tsx scripts/recommendation-diagnostic.ts",
    "item-model": "npx tsx scripts/item-model-diagnostic.ts",
    "group-model": "npx tsx scripts/group-model-diagnostic.ts",
    "bar-compare": "npx tsx scripts/progress-bar-compare.ts",
    "e2e": "npx tsx tests/e2e/skip-unskip.test.ts && npx tsx tests/e2e/quiz-flow.test.ts && npx tsx tests/e2e/navigation.test.ts && npx tsx tests/e2e/persistence.test.ts && npx tsx tests/e2e/chord-spelling.test.ts",
    "e2e:quiz": "npx tsx tests/e2e/quiz-flow.test.ts",
    "e2e:nav": "npx tsx tests/e2e/navigation.test.ts",
    "e2e:persist": "npx tsx tests/e2e/persistence.test.ts",
    "e2e:chord": "npx tsx tests/e2e/chord-spelling.test.ts",
    "e2e:skip": "npx tsx tests/e2e/skip-unskip.test.ts"
  }
}
