{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "command -v deno || npm install -g deno"
          },
          {
            "type": "command",
            "command": "if [ \"$IS_SANDBOX\" = \"yes\" ]; then npm install; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 scripts/hooks/require-git-unsandboxed.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "additionalDirectories": ["../.todos"],
     "allow": [
      "Bash(deno run:*)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(grep:*)",
      "Bash(npm install:*)",
      "Bash(npx tsx:*)",
      "Bash(git mv:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(git commit:*)",
      "Bash(test:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run:*)",
      "Bash(gh run view:*)",
      "Bash(gh api:*)",
      "WebFetch(domain:github.com)",
      "Bash(deno check:*)",
      "Bash(deno task build:*)",
      "Bash(deno task:*)",
      "Bash(deno fmt:*)",
      "Bash(npx playwright:*)"
    ]
  },
  "sandbox": {
    "enabled": true
  }
}
